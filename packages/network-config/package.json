{
  "name": "@gigadrive/network-config",
  "version": "3.4.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gigadrive/sdk.git",
    "directory": "packages/network-config"
  },
  "license": "Apache-2.0",
  "author": "Gigadrive <business@gigadrivegroup.com> (https://gigadrive.de)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./nextjs-adapter": {
      "types": "./dist/nextjs-adapter.d.ts",
      "require": "./dist/nextjs-adapter.cjs",
      "import": "./dist/nextjs-adapter.mjs"
    },
    "./nextjs-cache-handler": {
      "types": "./dist/nextjs-cache-handler.d.ts",
      "require": "./dist/nextjs-cache-handler.js",
      "import": "./dist/nextjs-cache-handler.mjs"
    },
    "./nextjs-cache-components-handler": {
      "types": "./dist/nextjs-cache-components-handler.d.ts",
      "require": "./dist/nextjs-cache-components-handler.js",
      "import": "./dist/nextjs-cache-components-handler.mjs"
    },
    "./nextjs-image-loader": {
      "types": "./dist/nextjs-image-loader.d.ts",
      "require": "./dist/nextjs-image-loader.js",
      "import": "./dist/nextjs-image-loader.mjs"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "**/*.json"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/v4 && cp -r ./src/v4/schema.json ./dist/v4/schema.json && cp ./src/nextjs-adapter.cjs ./dist/nextjs-adapter.cjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gigadrive/build-utils": "workspace:*",
    "@gigadrive/commons": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "minimatch": "^10.0.3",
    "safe-regex2": "^5.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.107.0",
    "@types/node": "^24.13.3",
    "effect": "^3.19.17",
    "esbuild": "^0.28.0",
    "next": "16.2.10"
  },
  "peerDependencies": {
    "@effect/platform": "^0.94.5 || ^0.96.0",
    "effect": "^3.19.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
