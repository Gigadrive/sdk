      "types": "./dist/buffered-readable-stream.d.ts",
      "require": "./dist/buffered-readable-stream.js",
      "import": "./dist/buffered-readable-stream.mjs"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "**/*.json"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
